rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    // All authenticated users can read properties to find their shop.
    match /properties/{propertyId} {
        allow read, write: if isSignedIn();
    }

    match /tenants/{tenantId} {
      // Any signed-in user can read tenant data. The tenant app will use this
      // to find the correct tenant record based on the selected shop.
      // The admin panel relies on this for its functionality.
      allow read: if isSignedIn();

      // The admin panel requires broad write access. The tenant app will be
      // given more specific update permissions by its own logic, such as
      // claiming an unlinked tenant record by setting the `uid`.
      allow write: if isSignedIn();

      // Rules for the payment_proofs subcollection nested under each tenant.
      match /payment_proofs/{proofId} {
        // Admins need to read all proofs. Tenants should only read their own.
        // This rule allows any signed-in user to read, but the tenant app's
        // UI must be built to only query its own path.
        allow read: if isSignedIn();

        // A tenant can ONLY create a payment proof under their own tenant record.
        // This is the most critical security rule for the tenant app.
        // It checks that the authenticated user's ID matches the `uid` field
        // in the parent tenant document.
        allow create: if isSignedIn() && get(/databases/$(database)/documents/tenants/$(tenantId)).data.uid == request.auth.uid;
        
        // Admins need to update proofs to approve/reject them.
        // This also allows a tenant to update/delete their own proofs, which is acceptable.
        allow update, delete: if isSignedIn();
      }
    }
  }
}
