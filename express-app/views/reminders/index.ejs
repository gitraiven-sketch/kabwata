<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <title>Reminders - Kabwata Shopping Complex</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            border: 'hsl(var(--border))',
            input: 'hsl(var(--input))',
            ring: 'hsl(var(--ring))',
            background: 'hsl(var(--background))',
            foreground: 'hsl(var(--foreground))',
            primary: {
              DEFAULT: 'hsl(var(--primary))',
              foreground: 'hsl(var(--primary-foreground))',
            },
            secondary: {
              DEFAULT: 'hsl(var(--secondary))',
              foreground: 'hsl(var(--secondary-foreground))',
            },
            destructive: {
              DEFAULT: 'hsl(var(--destructive))',
              foreground: 'hsl(var(--destructive-foreground))',
            },
            muted: {
              DEFAULT: 'hsl(var(--muted))',
              foreground: 'hsl(var(--muted-foreground))',
            },
            accent: {
              DEFAULT: 'hsl(var(--accent))',
              foreground: 'hsl(var(--accent-foreground))',
            },
            popover: {
              DEFAULT: 'hsl(var(--popover))',
              foreground: 'hsl(var(--popover-foreground))',
            },
            card: {
              DEFAULT: 'hsl(var(--card))',
              foreground: 'hsl(var(--card-foreground))',
            },
          },
          borderRadius: {
            lg: 'var(--radius)',
            md: 'calc(var(--radius) - 2px)',
            sm: 'calc(var(--radius) - 4px)',
          },
          fontFamily: {
            body: ['Inter', 'sans-serif'],
          },
        },
      },
    }
  </script>
  <style>
    :root {
      --background: 0 0% 100%;
      --foreground: 0 0% 11%;
      --card: 0 0% 96.1%;
      --card-foreground: 0 0% 11%;
      --popover: 0 0% 100%;
      --popover-foreground: 0 0% 11%;
      --primary: 158 100% 33%;
      --primary-foreground: 0 0% 100%;
      --secondary: 0 0% 96.1%;
      --secondary-foreground: 0 0% 11%;
      --muted: 0 0% 96.1%;
      --muted-foreground: 0 0% 45.1%;
      --accent: 45 100% 51%;
      --accent-foreground: 0 0% 11%;
      --destructive: 0 84.2% 60.2%;
      --destructive-foreground: 0 0% 100%;
      --border: 0 0% 89.8%;
      --input: 0 0% 89.8%;
      --ring: 158 100% 33%;
      --radius: 0.5rem;
    }

    * {
      border-color: hsl(var(--border));
    }

    body {
      background-color: hsl(var(--background));
      color: hsl(var(--foreground));
      font-family: 'Inter', sans-serif;
    }

    .sidebar {
      background-color: hsl(var(--card));
      border-right: 1px solid hsl(var(--border));
    }

    .sidebar .nav-link {
      color: hsl(var(--muted-foreground));
      transition: color 0.2s;
    }

    .sidebar .nav-link:hover {
      color: hsl(var(--foreground));
    }

    .sidebar .nav-link.active {
      color: hsl(var(--primary));
      background-color: hsl(var(--accent) / 0.1);
    }

    .card {
      background-color: hsl(var(--card));
      border: 1px solid hsl(var(--border));
      border-radius: var(--radius);
    }

    .btn-primary {
      background-color: hsl(var(--primary));
      border-color: hsl(var(--primary));
      color: hsl(var(--primary-foreground));
    }

    .btn-primary:hover {
      background-color: hsl(var(--primary) / 0.9);
      border-color: hsl(var(--primary) / 0.9);
    }

    .text-muted-foreground {
      color: hsl(var(--muted-foreground));
    }

    .status-paid {
      color: hsl(var(--primary));
    }

    .status-overdue {
      color: hsl(var(--destructive));
    }

    .status-upcoming {
      color: hsl(var(--accent));
    }

    .badge {
      display: inline-flex;
      align-items: center;
      border-radius: calc(var(--radius) - 2px);
      border: 1px solid transparent;
      padding: 0.125rem 0.5rem;
      font-size: 0.75rem;
      font-weight: 600;
      line-height: 1;
      transition: color 0.2s, background-color 0.2s, border-color 0.2s;
    }

    .badge-success {
      background-color: hsl(var(--primary) / 0.1);
      color: hsl(var(--primary));
    }

    .badge-danger {
      background-color: hsl(var(--destructive) / 0.1);
      color: hsl(var(--destructive));
    }

    .badge-warning {
      background-color: hsl(var(--accent) / 0.1);
      color: hsl(var(--accent));
    }
  </style>
</head>
<body class="font-body antialiased">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <nav class="sidebar w-64 flex-shrink-0">
      <div class="p-6">
        <h1 class="text-xl font-bold text-foreground mb-8">Kabwata Shopping Complex</h1>
        <ul class="space-y-2">
          <li>
            <a href="/" class="nav-link flex items-center px-4 py-2 rounded-md text-sm font-medium">
              <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5a2 2 0 012-2h4a2 2 0 012 2v2H8V5z"></path>
              </svg>
              Dashboard
            </a>
          </li>
          <li>
            <a href="/tenants" class="nav-link flex items-center px-4 py-2 rounded-md text-sm font-medium">
              <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
              </svg>
              Tenants
            </a>
          </li>
          <li>
            <a href="/properties" class="nav-link flex items-center px-4 py-2 rounded-md text-sm font-medium">
              <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
              </svg>
              Properties
            </a>
          </li>
          <li>
            <a href="/reminders" class="nav-link active flex items-center px-4 py-2 rounded-md text-sm font-medium">
              <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-5 5v-5zM4.868 12.683A17.925 17.925 0 0112 21c7.962 0 12-1.21 12-2.683m-12 2.683a17.925 17.925 0 01-7.132-8.317M12 21c4.411 0 8-4.03 8-9s-3.589-9-8-9-8 4.03-8 9a9.06 9.06 0 001.832 5.445L4 21l4.868-2.317z"></path>
              </svg>
              Reminders
            </a>
          </li>
        </ul>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1 bg-background">
      <div class="p-8">
        <div class="mb-8">
          <h1 class="text-3xl font-bold tracking-tight text-foreground">Reminders</h1>
          <p class="text-muted-foreground mt-2">Manage payment reminders and overdue notices.</p>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          <!-- Reminders -->
          <div class="card">
            <div class="p-6">
              <h3 class="text-lg font-semibold mb-4">Reminders</h3>
              <% if (reminders.length > 0) { %>
              <div class="space-y-4">
                <% reminders.forEach(reminder => { %>
                <div class="p-4 border border-border rounded-lg">
                  <div class="flex items-start justify-between">
                    <div class="flex-1">
                      <h4 class="font-medium"><%= reminder.title %></h4>
                      <p class="text-sm text-muted-foreground mt-1"><%= reminder.notes %></p>
                      <div class="flex items-center gap-2 mt-2">
                        <span class="inline-flex items-center px-2 py-1 text-xs font-medium bg-muted text-muted-foreground rounded">
                          <%= reminder.type %>
                        </span>
                      </div>
                    </div>
                    <div class="text-right">
                      <p class="text-sm text-muted-foreground"><%= new Date(reminder.dueDate).toLocaleDateString() %></p>
                    </div>
                  </div>
                </div>
                <% }); %>
              </div>
              <% } else { %>
              <p class="text-sm text-muted-foreground">No reminders set.</p>
              <% } %>
            </div>
          </div>

          <!-- Overdue Tenants -->
          <div class="card">
            <div class="p-6">
              <h3 class="text-lg font-semibold mb-4">Overdue Tenants</h3>
              <% if (overdueTenants.length > 0) { %>
              <div class="space-y-3">
                <% overdueTenants.forEach(tenant => { %>
                <div class="flex items-center justify-between py-3 border-b border-border last:border-b-0">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-muted flex items-center justify-center">
                      <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                      </svg>
                    </div>
                    <div>
                      <a href="/tenants/<%= tenant.id %>" class="font-medium hover:text-primary transition-colors">
                        <%= tenant.name %>
                      </a>
                      <p class="text-sm text-muted-foreground"><%= new Date(tenant.dueDate).toLocaleDateString() %></p>
                    </div>
                  </div>
                  <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                  </svg>
                </div>
                <% }); %>
              </div>
              <% } else { %>
              <div class="text-center py-8">
                <svg class="w-12 h-12 text-green-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <p class="text-sm text-muted-foreground">All tenants are up to date!</p>
              </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</body>
</html>