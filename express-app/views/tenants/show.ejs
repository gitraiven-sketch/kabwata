<div class="grid gap-6 md:grid-cols-2">
  <!-- Tenant Details -->
  <div class="card">
    <div class="p-6">
      <h3 class="text-lg font-semibold mb-4">Tenant Details</h3>
      <div class="space-y-3">
        <div>
          <label class="text-sm font-medium text-muted-foreground">Name</label>
          <p class="text-sm font-medium"><%= tenant.name %></p>
        </div>
        <div>
          <label class="text-sm font-medium text-muted-foreground">Phone</label>
          <p class="text-sm font-medium"><%= tenant.phone %></p>
        </div>
        <div>
          <label class="text-sm font-medium text-muted-foreground">Property</label>
          <p class="text-sm font-medium"><%= tenant.property.name %></p>
        </div>
        <div>
          <label class="text-sm font-medium text-muted-foreground">Lease Start</label>
          <p class="text-sm font-medium"><%= new Date(tenant.leaseStartDate).toLocaleDateString() %></p>
        </div>
        <div>
          <label class="text-sm font-medium text-muted-foreground">Payment Day</label>
          <p class="text-sm font-medium"><%= tenant.paymentDay %></p>
        </div>
        <div>
          <label class="text-sm font-medium text-muted-foreground">Payment Status</label>
          <span class="badge <%= tenant.paymentStatus === 'Paid' ? 'badge-success' : tenant.paymentStatus === 'Overdue' ? 'badge-danger' : 'badge-warning' %>">
            <%= tenant.paymentStatus %>
          </span>
        </div>
        <div>
          <label class="text-sm font-medium text-muted-foreground">Due Date</label>
          <p class="text-sm font-medium"><%= new Date(tenant.dueDate).toLocaleDateString() %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Payment History -->
  <div class="card">
    <div class="p-6">
      <h3 class="text-lg font-semibold mb-4">Payment History</h3>
      <% if (payments.length > 0) { %>
      <div class="space-y-3">
        <% payments.forEach(payment => { %>
        <div class="flex items-center justify-between py-2 border-b border-border last:border-b-0">
          <div>
            <p class="text-sm font-medium">ZMW <%= payment.amount %></p>
            <p class="text-xs text-muted-foreground"><%= new Date(payment.date).toLocaleDateString() %></p>
          </div>
          <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <% }); %>
      </div>
      <% } else { %>
      <p class="text-sm text-muted-foreground">No payment history available.</p>
      <% } %>
    </div>
  </div>
</div>