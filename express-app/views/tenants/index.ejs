<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <title>Tenants - Kabwata Shopping Complex</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            border: 'hsl(var(--border))',
            input: 'hsl(var(--input))',
            ring: 'hsl(var(--ring))',
            background: 'hsl(var(--background))',
            foreground: 'hsl(var(--foreground))',
            primary: {
              DEFAULT: 'hsl(var(--primary))',
              foreground: 'hsl(var(--primary-foreground))',
            },
            secondary: {
              DEFAULT: 'hsl(var(--secondary))',
              foreground: 'hsl(var(--secondary-foreground))',
            },
            destructive: {
              DEFAULT: 'hsl(var(--destructive))',
              foreground: 'hsl(var(--destructive-foreground))',
            },
            muted: {
              DEFAULT: 'hsl(var(--muted))',
              foreground: 'hsl(var(--muted-foreground))',
            },
            accent: {
              DEFAULT: 'hsl(var(--accent))',
              foreground: 'hsl(var(--accent-foreground))',
            },
            popover: {
              DEFAULT: 'hsl(var(--popover))',
              foreground: 'hsl(var(--popover-foreground))',
            },
            card: {
              DEFAULT: 'hsl(var(--card))',
              foreground: 'hsl(var(--card-foreground))',
            },
          },
          borderRadius: {
            lg: 'var(--radius)',
            md: 'calc(var(--radius) - 2px)',
            sm: 'calc(var(--radius) - 4px)',
          },
          fontFamily: {
            body: ['Inter', 'sans-serif'],
          },
        },
      },
    }
  </script>
  <style>
    :root {
      --background: 0 0% 100%;
      --foreground: 0 0% 11%;
      --card: 0 0% 96.1%;
      --card-foreground: 0 0% 11%;
      --popover: 0 0% 100%;
      --popover-foreground: 0 0% 11%;
      --primary: 158 100% 33%;
      --primary-foreground: 0 0% 100%;
      --secondary: 0 0% 96.1%;
      --secondary-foreground: 0 0% 11%;
      --muted: 0 0% 96.1%;
      --muted-foreground: 0 0% 45.1%;
      --accent: 45 100% 51%;
      --accent-foreground: 0 0% 11%;
      --destructive: 0 84.2% 60.2%;
      --destructive-foreground: 0 0% 100%;
      --border: 0 0% 89.8%;
      --input: 0 0% 89.8%;
      --ring: 158 100% 33%;
      --radius: 0.5rem;
    }

    * {
      border-color: hsl(var(--border));
    }

    body {
      background-color: hsl(var(--background));
      color: hsl(var(--foreground));
      font-family: 'Inter', sans-serif;
    }

    .sidebar {
      background-color: hsl(var(--card));
      border-right: 1px solid hsl(var(--border));
    }

    .sidebar .nav-link {
      color: hsl(var(--muted-foreground));
      transition: color 0.2s;
    }

    .sidebar .nav-link:hover {
      color: hsl(var(--foreground));
    }

    .sidebar .nav-link.active {
      color: hsl(var(--primary));
      background-color: hsl(var(--accent) / 0.1);
    }

    .card {
      background-color: hsl(var(--card));
      border: 1px solid hsl(var(--border));
      border-radius: var(--radius);
    }

    .btn-primary {
      background-color: hsl(var(--primary));
      border-color: hsl(var(--primary));
      color: hsl(var(--primary-foreground));
    }

    .btn-primary:hover {
      background-color: hsl(var(--primary) / 0.9);
      border-color: hsl(var(--primary) / 0.9);
    }

    .text-muted-foreground {
      color: hsl(var(--muted-foreground));
    }

    .status-paid {
      background-color: hsl(var(--primary));
      color: hsl(var(--primary-foreground));
    }

    .status-overdue {
      background-color: hsl(var(--destructive));
      color: hsl(var(--destructive-foreground));
    }

    .status-upcoming {
      background-color: hsl(var(--accent));
      color: hsl(var(--accent-foreground));
    }

    .status-archived {
      background-color: hsl(var(--muted));
      color: hsl(var(--muted-foreground));
    }

    .badge {
      display: inline-flex;
      align-items: center;
      border-radius: calc(var(--radius) - 2px);
      border: 1px solid transparent;
      padding: 0.125rem 0.5rem;
      font-size: 0.75rem;
      font-weight: 600;
      line-height: 1;
      transition: color 0.2s, background-color 0.2s, border-color 0.2s;
    }

    .badge-success {
      background-color: hsl(var(--primary) / 0.1);
      color: hsl(var(--primary));
    }

    .badge-danger {
      background-color: hsl(var(--destructive) / 0.1);
      color: hsl(var(--destructive));
    }

    .badge-warning {
      background-color: hsl(var(--accent) / 0.1);
      color: hsl(var(--accent));
    }

    .tabs-list {
      display: flex;
      background-color: hsl(var(--muted) / 0.5);
      border-radius: var(--radius);
      padding: 0.25rem;
    }

    .tab-trigger {
      flex: 1;
      padding: 0.5rem 1rem;
      border-radius: calc(var(--radius) - 2px);
      font-size: 0.875rem;
      font-weight: 500;
      color: hsl(var(--muted-foreground));
      background: transparent;
      border: none;
      cursor: pointer;
      transition: color 0.2s, background-color 0.2s;
    }

    .tab-trigger.active {
      background-color: hsl(var(--background));
      color: hsl(var(--foreground));
      box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
    }

    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
    }

    .tenant-card {
      background-color: hsl(var(--card));
      border: 1px solid hsl(var(--border));
      border-radius: var(--radius);
      padding: 1rem;
      transition: all 0.2s;
      break-inside: avoid;
    }

    .tenant-card:hover {
      box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
      transform: translateY(-2px);
    }

    .tenant-card.paid {
      background-color: hsl(var(--primary));
      color: hsl(var(--primary-foreground));
    }

    .tenant-card.overdue {
      background-color: hsl(var(--destructive));
      color: hsl(var(--destructive-foreground));
    }

    .tenant-card.upcoming {
      background-color: hsl(var(--accent));
      color: hsl(var(--accent-foreground));
    }

    .tenant-card.archived {
      background-color: hsl(var(--background));
      color: hsl(var(--foreground));
      border: 1px solid hsl(var(--border));
      box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
    }

    .tenant-avatar {
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid hsl(var(--white) / 0.5);
    }

    .tenant-avatar.paid {
      background-color: hsl(var(--white) / 0.2);
    }

    .tenant-avatar.overdue {
      background-color: hsl(var(--white) / 0.2);
    }

    .tenant-avatar.upcoming {
      background-color: hsl(var(--white) / 0.2);
    }

    .tenant-avatar.archived {
      background-color: hsl(var(--muted));
    }

    .columns-3 {
      column-count: 3;
      column-gap: 1.5rem;
    }

    @media (max-width: 768px) {
      .columns-3 {
        column-count: 1;
      }
    }
  </style>
  <script>
    function showTab(tabName) {
      // Hide all tab contents
      const tabContents = document.querySelectorAll('.tab-content');
      tabContents.forEach(content => content.classList.remove('active'));

      // Remove active class from all triggers
      const tabTriggers = document.querySelectorAll('.tab-trigger');
      tabTriggers.forEach(trigger => trigger.classList.remove('active'));

      // Show selected tab content
      const selectedTab = document.getElementById(tabName);
      if (selectedTab) {
        selectedTab.classList.add('active');
      }

      // Add active class to selected trigger
      const selectedTrigger = document.querySelector(`[data-tab="${tabName}"]`);
      if (selectedTrigger) {
        selectedTrigger.classList.add('active');
      }
    }

    // Initialize first tab as active
    document.addEventListener('DOMContentLoaded', function() {
      const firstTab = document.querySelector('.tab-trigger');
      if (firstTab) {
        const tabName = firstTab.getAttribute('data-tab');
        showTab(tabName);
      }
    });
  </script>
</head>
<body class="font-body antialiased">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <nav class="sidebar w-64 flex-shrink-0">
      <div class="p-6">
        <h1 class="text-xl font-bold text-foreground mb-8">Kabwata Shopping Complex</h1>
        <ul class="space-y-2">
          <li>
            <a href="/" class="nav-link flex items-center px-4 py-2 rounded-md text-sm font-medium">
              <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5a2 2 0 012-2h4a2 2 0 012 2v2H8V5z"></path>
              </svg>
              Dashboard
            </a>
          </li>
          <li>
            <a href="/tenants" class="nav-link active flex items-center px-4 py-2 rounded-md text-sm font-medium">
              <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
              </svg>
              Tenants
            </a>
          </li>
          <li>
            <a href="/properties" class="nav-link flex items-center px-4 py-2 rounded-md text-sm font-medium">
              <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
              </svg>
              Properties
            </a>
          </li>
          <li>
            <a href="/reminders" class="nav-link flex items-center px-4 py-2 rounded-md text-sm font-medium">
              <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-5 5v-5zM4.868 12.683A17.925 17.925 0 0112 21c7.962 0 12-1.21 12-2.683m-12 2.683a17.925 17.925 0 01-7.132-8.317M12 21c4.411 0 8-4.03 8-9s-3.589-9-8-9-8 4.03-8 9a9.06 9.06 0 001.832 5.445L4 21l4.868-2.317z"></path>
              </svg>
              Reminders
            </a>
          </li>
        </ul>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1 bg-background">
      <div class="p-8">
        <div class="mb-8">
          <h1 class="text-3xl font-bold tracking-tight text-foreground">Tenants</h1>
          <p class="text-muted-foreground mt-2">Manage all tenants in your complex.</p>
        </div>

        <div class="card">
          <div class="p-6">
            <!-- Tabs -->
            <div class="sticky top-20 z-10 border-b bg-background/95 py-2 backdrop-blur-sm mb-6">
              <div class="tabs-list">
                <% const groups = ['Group A', 'Group B', 'Group C']; %>
                <% groups.forEach((group, index) => { %>
                  <% const groupTenants = tenants.filter(t => t.property.group === group); %>
                  <% if (groupTenants.length > 0) { %>
                    <button
                      class="tab-trigger <%= index === 0 ? 'active' : '' %>"
                      data-tab="<%= group.replace(' ', '') %>"
                      onclick="showTab('<%= group.replace(' ', '') %>')"
                    >
                      <%= group %>
                    </button>
                  <% } %>
                <% }); %>
              </div>
            </div>

            <!-- Tab Contents -->
            <% groups.forEach((group, index) => { %>
              <% const groupTenants = tenants.filter(t => t.property.group === group); %>
              <% if (groupTenants.length > 0) { %>
                <div id="<%= group.replace(' ', '') %>" class="tab-content <%= index === 0 ? 'active' : '' %>">
                  <div class="pt-6">
                    <div class="columns-3 gap-6 space-y-6">
                      <% groupTenants.forEach(tenant => { %>
                        <div class="tenant-card <%= tenant.paymentStatus === 'Paid' && !tenant.isArchived ? 'paid' : tenant.paymentStatus === 'Overdue' && !tenant.isArchived ? 'overdue' : tenant.paymentStatus === 'Upcoming' && !tenant.isArchived ? 'upcoming' : 'archived' %>">
                          <div class="flex items-start justify-between pb-4">
                            <div class="flex items-center gap-4">
                              <div class="tenant-avatar <%= tenant.paymentStatus === 'Paid' && !tenant.isArchived ? 'paid' : tenant.paymentStatus === 'Overdue' && !tenant.isArchived ? 'overdue' : tenant.paymentStatus === 'Upcoming' && !tenant.isArchived ? 'upcoming' : 'archived' %>">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                </svg>
                              </div>
                              <div>
                                <h3 class="text-lg font-semibold"><%= tenant.name %></h3>
                                <p class="text-sm opacity-80"><%= tenant.property.name %></p>
                              </div>
                            </div>
                          </div>
                          <div class="flex items-center justify-between">
                            <div class="text-sm">
                              <p class="opacity-80">Due: <%= new Date(tenant.dueDate).toLocaleDateString() %></p>
                            </div>
                            <a href="/tenants/<%= tenant.id %>" class="inline-flex items-center px-3 py-1 text-sm font-medium hover:opacity-80 rounded-md transition-colors">
                              View
                            </a>
                          </div>
                        </div>
                      <% }); %>
                    </div>
                  </div>
                </div>
              <% } %>
            <% }); %>
          </div>
        </div>
      </div>
    </main>
  </div>
</body>
</html>