<div class="grid gap-6 md:grid-cols-2">
  <!-- Property Details -->
  <div class="card">
    <div class="p-6">
      <h3 class="text-lg font-semibold mb-4">Property Details</h3>
      <div class="space-y-3">
        <div>
          <label class="text-sm font-medium text-muted-foreground">Name</label>
          <p class="text-sm font-medium"><%= property.name %></p>
        </div>
        <div>
          <label class="text-sm font-medium text-muted-foreground">Group</label>
          <p class="text-sm font-medium"><%= property.group %></p>
        </div>
        <div>
          <label class="text-sm font-medium text-muted-foreground">Shop Number</label>
          <p class="text-sm font-medium"><%= property.shopNumber %></p>
        </div>
        <div>
          <label class="text-sm font-medium text-muted-foreground">Address</label>
          <p class="text-sm font-medium"><%= property.address %></p>
        </div>
        <div>
          <label class="text-sm font-medium text-muted-foreground">Payment Day</label>
          <p class="text-sm font-medium"><%= property.paymentDay %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Tenants -->
  <div class="card">
    <div class="p-6">
      <h3 class="text-lg font-semibold mb-4">Tenants</h3>
      <% if (tenants.length > 0) { %>
      <div class="space-y-3">
        <% tenants.forEach(tenant => { %>
        <div class="flex items-center justify-between py-3 border-b border-border last:border-b-0">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-muted flex items-center justify-center">
              <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
            </div>
            <div>
              <a href="/tenants/<%= tenant.id %>" class="font-medium hover:text-primary transition-colors">
                <%= tenant.name %>
              </a>
              <p class="text-sm text-muted-foreground"><%= tenant.phone %></p>
            </div>
          </div>
          <span class="badge <%= tenant.paymentStatus === 'Paid' ? 'badge-success' : tenant.paymentStatus === 'Overdue' ? 'badge-danger' : 'badge-warning' %>">
            <%= tenant.paymentStatus %>
          </span>
        </div>
        <% }); %>
      </div>
      <% } else { %>
      <p class="text-sm text-muted-foreground">No tenants assigned to this property.</p>
      <% } %>
    </div>
  </div>
</div>