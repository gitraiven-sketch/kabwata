
{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "A tenant in the shopping complex.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier for the tenant."
        },
        "uid": {
            "type": "string",
            "description": "The Firebase Auth UID of the tenant's user account, linking their login to their tenant record."
        },
        "name": {
          "type": "string",
          "description": "The name of the tenant."
        },
        "phone": {
          "type": "string",
          "description": "The phone number of the tenant."
        },
        "propertyId": {
          "type": "string",
          "description": "The ID of the property the tenant is renting."
        },
        "paymentDay": {
          "type": "number",
          "description": "The day of the month rent is due."
        },
        "leaseStartDate": {
          "type": "string",
          "format": "date",
          "description": "The start date of the lease."
        },
        "lastPaidDate": {
          "type": "string",
          "format": "date-time",
          "description": "The last date a payment was recorded for this tenant."
        },
        "isArchived": {
            "type": "boolean",
            "description": "Whether the tenant's lease has ended. Archived tenants are hidden from active lists."
        }
      },
      "required": [
        "name",
        "phone",
        "propertyId",
        "paymentDay",
        "leaseStartDate"
      ]
    },
    "Property": {
        "title": "Property",
        "description": "A shop in the shopping complex.",
        "type": "object",
        "properties": {
            "id": {
                "type": "string",
                "description": "The unique identifier for the property."
            },
            "name": {
                "type": "string"
            },
            "group": {
                "type": "string"
            },
            "shopNumber": {
                "type": "number"
            },
            "address": {
                "type": "string"
            },
            "paymentDay": {
                "type": "number"
            }
        },
        "required": ["name", "group", "shopNumber", "address", "paymentDay"]
    },
    "PaymentProof": {
        "title": "Payment Proof",
        "description": "A record of a tenant's submitted proof of payment.",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "tenantId": { "type": "string" },
            "imageUrl": { "type": "string", "format": "uri" },
            "uploadedAt": { "type": "string", "format": "date-time" },
            "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
            "adminNotes": { "type": "string" }
        },
        "required": ["tenantId", "imageUrl", "uploadedAt", "status"]
    },
    "Payment": {
        "title": "Payment",
        "description": "A record of a payment made by a tenant, including rent and electricity.",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "tenantId": { "type": "string" },
            "rentAmount": { "type": "number" },
            "electricityAmount": { "type": "number" },
            "datePaid": { "type": "string", "format": "date-time" },
            "linkedProofId": { "type": "string", "description": "ID of the payment proof this record is based on, if any." }
        },
        "required": ["tenantId", "rentAmount", "electricityAmount", "datePaid"]
    }
  },
  "auth": {
    "providers": [
      "email-password"
    ]
  },
  "firestore": {
    "/tenants/{tenantId}": {
      "schema": {
        "$ref": "#/entities/Tenant"
      },
      "description": "Collection of all tenants."
    },
    "/tenants/{tenantId}/payment_proofs/{proofId}": {
      "schema": {
        "$ref": "#/entities/PaymentProof"
      },
      "description": "Collection of payment proofs submitted by a tenant."
    },
    "/tenants/{tenantId}/payments/{paymentId}": {
        "schema": { "$ref": "#/entities/Payment" },
        "description": "Historical log of all payments made by a tenant."
    },
    "/properties/{propertyId}": {
        "schema": {
            "$ref": "#/entities/Property"
        },
        "description": "Collection of all properties."
    }
  }
}
